          <hashTree>
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="IBAN JSON Extractor">
              <stringProp name="JSONPostProcessor.referenceNames">myIban;myFirstName;myLastName</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.accountNumber;$.user.firstName;$.user.lastName</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">1</stringProp>
              <stringProp name="JSONPostProcessor.defaultValues">NONE;NONE;NONE</stringProp>
            </JSONPostProcessor>
            <hashTree/>
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="Transfer Entry JSR223 PostProcessor">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def token = vars.get(&quot;myJwtToken&quot;)
def iban = vars.get(&quot;myIban&quot;)
def nome = vars.get(&quot;myFirstName&quot;)
def cognome = vars.get(&quot;myLastName&quot;)

// Verifico che il token sia un JWT valido (contiene punti)
if (token != null &amp;&amp; token.contains(&quot;.&quot;)) {
    def identity = &quot;${token}|${iban}|${nome}|${cognome}&quot;
    def pool = props.get(&quot;AUTH_USER_POOL&quot;)
    
    if (pool == null) {
        pool = Collections.synchronizedList(new ArrayList())
        props.put(&quot;AUTH_USER_POOL&quot;, pool)
    }
    
    if (!pool.contains(identity)) {
        pool.add(identity)
    }
}</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
            <hashTree/>
            <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
              <collectionProp name="HeaderManager.headers">
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Content-Type</stringProp>
                  <stringProp name="Header.value">application/json</stringProp>
                </elementProp>
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Authorization</stringProp>
                  <stringProp name="Header.value">Bearer ${myJwtToken}</stringProp>
                </elementProp>
              </collectionProp>
            </HeaderManager>
            <hashTree/>
          </hashTree>
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Transfer Request">
            <stringProp name="HTTPSampler.domain">localhost</stringProp>
            <stringProp name="HTTPSampler.port">${PORT}</stringProp>
            <stringProp name="HTTPSampler.protocol">http</stringProp>
            <stringProp name="HTTPSampler.path">/api/transactions/transfer</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">true</boolProp>
            <stringProp name="HTTPSampler.method">POST</stringProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPsampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{&#xd;
    &quot;amount&quot;: &quot;${__Random(1,500)}&quot;,&#xd;
    &quot;type&quot;: &quot;OUT&quot;,&#xd;
    &quot;relatedAccountNumber&quot;: &quot;${DEST_IBAN}&quot;,&#xd;
    &quot;description&quot;: &quot;Stress Test - Thread ${__threadNum}&quot;,&#xd;
    &quot;recipientFirstName&quot;: &quot;${DEST_NOME}&quot;,&#xd;
    &quot;recipientLastName&quot;: &quot;${DEST_COGNOME}&quot;&#xd;
}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
          </HTTPSamplerProxy>
          <hashTree>
            <HeaderManager guiclass="HeaderPanel" testclass="HeaderManager" testname="HTTP Header Manager" enabled="true">
              <collectionProp name="HeaderManager.headers">
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Content-Type</stringProp>
                  <stringProp name="Header.value">application/json</stringProp>
                </elementProp>
                <elementProp name="" elementType="Header">
                  <stringProp name="Header.name">Authorization</stringProp>
                  <stringProp name="Header.value">Bearer ${CURRENT_TOKEN}</stringProp>
                </elementProp>
              </collectionProp>
            </HeaderManager>
            <hashTree/>
            <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="Transfer Entry JSR223 PreProcessor" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def pool = props.get(&quot;AUTH_USER_POOL&quot;)

if (pool != null &amp;&amp; pool.size() &gt; 0) {
    // Sceglie un utente a caso
    def randomIndex = new Random().nextInt(pool.size())
    def userPackage = pool.get(randomIndex)
    def parts = userPackage.split(&quot;\\|&quot;)
    
    // Crea le variabili per la Transfer Request
    vars.put(&quot;CURRENT_TOKEN&quot;, parts[0])
    vars.put(&quot;DEST_IBAN&quot;, parts[1])
    vars.put(&quot;DEST_NOME&quot;, parts[2])
    vars.put(&quot;DEST_COGNOME&quot;, parts[3])
}</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PreProcessor>
            <hashTree/>
          </hashTree>
